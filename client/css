/* Custom Premium Transitions & Interaction Tokens */
:root {
  --indigo-primary: #4f46e5;
  --transition-smooth: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

/* 1. Glassmorphism Design for Notification Modal */
#notificationModal {
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  transition: opacity 0.3s ease;
}

#notificationModal > div {
  animation: modalSlideIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

@keyframes modalSlideIn {
  from {
    transform: translateY(-10px) scale(0.95);
    opacity: 0;
  }
  to {
    transform: translateY(0) scale(1);
    opacity: 1;
  }
}

/* 2. Premium Sidebar Buttons Dynamic Active Indicators */
#sidebarNav button {
  position: relative;
  transition: var(--transition-smooth);
}

#sidebarNav button::after {
  content: '';
  position: absolute;
  left: 0;
  top: 25%;
  height: 50%;
  w-width: 4px;
  background-color: var(--indigo-primary);
  border-radius: 0 4px 4px 0;
  transform: scaleX(0);
  transition: var(--transition-smooth);
}

#sidebarNav button.text-indigo-600::after {
  transform: scaleX(1);
}

/* 3. Minimalist Premium Scrollbars (Mac-style) */
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: #cbd5e1;
  border-radius: 10px;
}

::-webkit-scrollbar-thumb:hover {
  background: #94a3b8;
}

/* 4. Soft Micro-Shadows & Interactivity on Dynamic Cards */
.grid > div, table tr {
  transition: var(--transition-smooth);
}

/* Table Row subtle hover highlight */
#ledgerList tr:hover {
  background-color: rgba(248, 250, 252, 0.8) !important;
  transform: translateX(2px);
}

/* Textarea subtle focus glowing ring */
textarea:focus {
  box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.12);
}